# Copier en .env à la racine pour surcharger les valeurs utilisées par docker-compose.
# Secret de signature des JWT — À CHANGER en production (chaîne longue et aléatoire).
JWT_SECRET=change-me-in-production
# Origine publique du frontend (pour CORS). En local : http://localhost:8080
CORS_ORIGIN=http://localhost:8080
# Extraction des tableaux par modèle de vision (optionnel, recommandé). Vide → OCR local.
# Clé Google AI Studio : https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
