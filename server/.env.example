# Copier ce fichier en .env et adapter les valeurs.
PORT=4000
# Secret de signature des JWT — À CHANGER en production.
JWT_SECRET=dev-secret-change-me
# Origine autorisée pour CORS (frontend Vite).
CORS_ORIGIN=http://localhost:5173
# Extraction par modèle de vision (optionnel). Si absent, l'app utilise l'OCR local.
# Clé API Google AI Studio : https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Paiement en plusieurs fois via Alma (optionnel). Si absent, la simulation s'affiche
# mais le paiement en ligne reste désactivé. Clé marchand : https://dashboard.getalma.eu
ALMA_API_KEY=
# "sandbox" (test) ou "live" (production).
ALMA_MODE=sandbox
# Paiement en plusieurs fois via Klarna (optionnel). Identifiants : portal.klarna.com
KLARNA_USERNAME=
KLARNA_PASSWORD=
KLARNA_REGION=eu
# "playground" (test) ou "live" (production).
KLARNA_MODE=playground
# E-mail transactionnel (espace patient) + SMS via Brevo. Sans clé, le lien s'affiche à l'écran
# au lieu d'être envoyé. Clé : https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
# Expéditeur e-mail VÉRIFIÉ chez Brevo (obligatoire pour l'envoi d'e-mails).
EMAIL_SENDER=
EMAIL_SENDER_NAME=Tableau de Garanti
# URL publique de l'app (pour les liens dans les e-mails/SMS). En prod : https://mon-domaine.fr
APP_BASE_URL=http://localhost:5173
