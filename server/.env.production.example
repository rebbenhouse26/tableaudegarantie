# ─────────────────────────────────────────────────────────────────────────────
# Variables d'environnement de PRODUCTION (à définir comme SECRETS sur l'hébergeur,
# jamais committées). Copie de référence — ne pas mettre de vraies valeurs ici.
# ─────────────────────────────────────────────────────────────────────────────

# --- Cœur ---
PORT=4000
NODE_ENV=production
# Secret de signature JWT — OBLIGATOIRE en prod. Générer : openssl rand -hex 32
JWT_SECRET=
# Origine autorisée (le domaine public du front). Ex : https://app.mon-cabinet.fr
CORS_ORIGIN=https://app.mon-domaine.fr
# URL publique de l'app (liens dans e-mails / SMS / paiements). Ex : https://app.mon-domaine.fr
APP_BASE_URL=https://app.mon-domaine.fr
# Base SQLite sur un VOLUME PERSISTANT chiffré (à sauvegarder). Données de santé !
DB_PATH=/api/data/tableau-de-garanti.db

# --- Extraction IA (Gemini) ---  ⚠️ régénérer la clé (l'ancienne est compromise)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- E-mail + SMS (Brevo) ---
BREVO_API_KEY=
EMAIL_SENDER=noreply@mon-domaine.fr      # adresse VÉRIFIÉE chez Brevo (SPF/DKIM)
EMAIL_SENDER_NAME=Tableau de Garanti
SMS_SENDER=Cabinet                        # ≤ 11 caractères alphanumériques

# --- Paiement en plusieurs fois ---
# Alma (https://dashboard.getalma.eu)
ALMA_API_KEY=
ALMA_MODE=live                            # "sandbox" en test, "live" en prod
# Klarna (https://portal.klarna.com → Settings > API credentials)
KLARNA_USERNAME=
KLARNA_PASSWORD=
KLARNA_REGION=eu                          # eu | na | oc
KLARNA_MODE=live                          # "playground" en test, "live" en prod
